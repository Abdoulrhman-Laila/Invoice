PORT=3000

# PostgreSQL (اختر أحد الخيارين)
# 1) رابط واحد:
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/invoice_db

# 2) متغيرات منفصلة:
PGHOST=localhost
PGPORT=5432
PGDATABASE=invoice_db
PGUSER=postgres
PGPASSWORD=change_me
PGSSL=false
# PGSSL_REJECT_UNAUTHORIZED=true

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# PDF (puppeteer-core + Chrome/Edge مثبت — مناسب للإنتاج بدون تحميل Chromium)
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# حد أقصى لطلبات PDF المتزامنة (يحمي الذاكرة على السيرفر)
# PDF_MAX_CONCURRENT=4
# مهلة عمليات setContent/pdf بالمللي ثانية
# PDF_OPERATION_TIMEOUT_MS=45000
# على سيرفر بدون إنترنت: عطّل خطوط Google (يعتمد على خطوط النظام — ثبّت fonts-noto على Linux)
# PDF_USE_REMOTE_FONTS=false

